@startuml c4-context
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.11.0/C4_Context.puml

' Modern flat styling: no shadows, sharper corners, clean sans-serif, modern palette.
skinparam backgroundColor #FAFAFA
skinparam shadowing false
skinparam roundCorner 4
skinparam defaultFontName "Inter, Helvetica, Arial, sans-serif"
skinparam defaultFontSize 13
skinparam ArrowColor #37474F
skinparam ArrowThickness 1.2
skinparam rectangleBorderThickness 1.3

UpdateElementStyle("person",          $fontColor="#FFFFFF", $bgColor="#0F766E", $borderColor="#134E4A")
UpdateElementStyle("system",          $fontColor="#FFFFFF", $bgColor="#2563EB", $borderColor="#1E3A8A")
UpdateElementStyle("system_ext",      $fontColor="#FFFFFF", $bgColor="#7C3AED", $borderColor="#4C1D95")
UpdateElementStyle("external_system", $fontColor="#FFFFFF", $bgColor="#7C3AED", $borderColor="#4C1D95")

title System Context — go-face-recognition

Person(operator, "Operator / Consumer", "Runs the binary or pulls the image")

System(gfr, "go-face-recognition", "Go CLI: classifies faces in baked-in images/unknown.jpg against persons/*, writes annotated result.jpg")

System_Ext(gface, "go-face/dlib{19,20}", "Upstream builder image (CGO + dlib + libdlib.a)")
System_Ext(dlib, "dlib-docker", "Upstream base (Ubuntu + compiled dlib)")
System_Ext(ghcr, "GHCR", "Container registry + release tarballs")
System_Ext(sigstore, "Sigstore", "Fulcio + Rekor (keyless OIDC)")

Rel(dlib, gface, "Digest-pinned FROM", "OCI")
Rel(gface, gfr, "Digest-pinned FROM (per matrix cell)", "OCI")
Rel(gfr, ghcr, "Push multi-arch image + release tarballs", "OCI")
Rel(gfr, sigstore, "Sign image digest + blob attest checksums", "OIDC")
Rel(operator, ghcr, "Pull image / download tarball", "HTTPS")
Rel(operator, sigstore, "Verify signature / attestation", "HTTPS")

SHOW_LEGEND()
@enduml
